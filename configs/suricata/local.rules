# =============================================================================
# Règles Suricata Personnalisées — Network Security Lab
# Auteur : axo9cyber
# Description : Règles de détection pour les scénarios du lab
# =============================================================================
# Format : action proto src_ip src_port direction dst_ip dst_port (options)
# =============================================================================

# -----------------------------------------------------------------------------
# CATÉGORIE : SCAN DE PORTS
# -----------------------------------------------------------------------------

# Détection d'un scan SYN (Nmap -sS)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"LAB-SCAN Possible SYN Scan Detected";
    flags:S,12;
    threshold: type both, track by_src, count 20, seconds 2;
    classtype:attempted-recon;
    sid:9000001; rev:1;
)

# Détection d'un scan de ports UDP
alert udp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"LAB-SCAN UDP Port Scan Detected";
    threshold: type both, track by_src, count 30, seconds 5;
    classtype:attempted-recon;
    sid:9000002; rev:1;
)

# Détection du User-Agent Nmap
alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"LAB-SCAN Nmap HTTP User-Agent Detected";
    content:"Nmap Scripting Engine";
    http_user_agent;
    classtype:attempted-recon;
    sid:9000003; rev:1;
)

# Détection Masscan
alert tcp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"LAB-SCAN Masscan Port Scanner Detected";
    flags:S;
    window:1024;
    threshold: type both, track by_src, count 50, seconds 3;
    classtype:attempted-recon;
    sid:9000004; rev:1;
)

# -----------------------------------------------------------------------------
# CATÉGORIE : FORCE BRUTE
# -----------------------------------------------------------------------------

# Détection d'une attaque brute-force SSH
alert tcp $EXTERNAL_NET any -> $HOME_NET $SSH_PORTS (
    msg:"LAB-BRUTEFORCE SSH Brute Force Attempt";
    flow:to_server,established;
    content:"SSH-";
    threshold: type both, track by_src, count 5, seconds 60;
    classtype:attempted-admin;
    sid:9001001; rev:1;
)

# Détection d'échecs d'authentification SSH répétés
alert tcp $HOME_NET $SSH_PORTS -> $EXTERNAL_NET any (
    msg:"LAB-BRUTEFORCE Multiple SSH Auth Failures";
    flow:to_client,established;
    content:"Authentication failed";
    threshold: type both, track by_dst, count 5, seconds 60;
    classtype:attempted-admin;
    sid:9001002; rev:1;
)

# Détection Hydra (HTTP POST brute-force)
alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"LAB-BRUTEFORCE Hydra HTTP Login Brute Force";
    flow:to_server,established;
    content:"POST";
    http_method;
    content:"/login";
    http_uri;
    threshold: type both, track by_src, count 10, seconds 30;
    classtype:attempted-admin;
    sid:9001003; rev:1;
)

# -----------------------------------------------------------------------------
# CATÉGORIE : SCAN DE VULNÉRABILITÉS WEB
# -----------------------------------------------------------------------------

# Détection du scanner Nikto
alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"LAB-SCAN Nikto Web Vulnerability Scanner";
    content:"Nikto";
    http_user_agent;
    classtype:web-application-attack;
    sid:9002001; rev:1;
)

# Détection de tentative de traversée de répertoire
alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"LAB-WEBAPP Directory Traversal Attempt";
    flow:to_server,established;
    content:"../";
    http_uri;
    pcre:"/(\.\./){3,}/U";
    classtype:web-application-attack;
    sid:9002002; rev:1;
)

# Détection de tentative SQLi basique
alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"LAB-WEBAPP SQL Injection Attempt";
    flow:to_server,established;
    pcre:"/(\%27)|(\')|(\-\-)|(\%23)|(#)/i";
    http_uri;
    classtype:web-application-attack;
    sid:9002003; rev:1;
)

# Détection de tentative XSS basique
alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"LAB-WEBAPP XSS Attempt Detected";
    flow:to_server,established;
    content:"<script>";
    http_client_body;
    nocase;
    classtype:web-application-attack;
    sid:9002004; rev:1;
)

# Détection de tentative d'injection de commande
alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"LAB-WEBAPP Command Injection Attempt";
    flow:to_server,established;
    pcre:"/(\;|\||\`|\$\()/";
    http_uri;
    classtype:web-application-attack;
    sid:9002005; rev:1;
)

# Détection Gobuster / dirsearch (scan de répertoires)
alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"LAB-SCAN Directory Brute Force Tool Detected";
    flow:to_server,established;
    pcre:"/gobuster|dirsearch|dirb|wfuzz/i";
    http_user_agent;
    classtype:attempted-recon;
    sid:9002006; rev:1;
)

# -----------------------------------------------------------------------------
# CATÉGORIE : ACTIVITÉ ICMP SUSPECTE
# -----------------------------------------------------------------------------

# Détection d'un ping sweep (ICMP flood)
alert icmp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"LAB-RECON ICMP Ping Sweep Detected";
    itype:8;
    threshold: type both, track by_src, count 10, seconds 5;
    classtype:attempted-recon;
    sid:9003001; rev:1;
)

# Détection d'un ping de grande taille (possible test DoS)
alert icmp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"LAB-DOS Large ICMP Packet Detected";
    itype:8;
    dsize:>1000;
    classtype:attempted-dos;
    sid:9003002; rev:1;
)

# -----------------------------------------------------------------------------
# CATÉGORIE : EXFILTRATION / ACTIVITÉ C2 SUSPECTE
# -----------------------------------------------------------------------------

# Détection de connexion IRC (possible C2)
alert tcp $HOME_NET any -> $EXTERNAL_NET 6667 (
    msg:"LAB-C2 Outbound IRC Connection Possible Botnet";
    flow:to_server,established;
    classtype:trojan-activity;
    sid:9004001; rev:1;
)

# Détection de transfert de données volumineux sortant
alert tcp $HOME_NET any -> $EXTERNAL_NET any (
    msg:"LAB-EXFIL Large Outbound Data Transfer";
    flow:to_server,established;
    dsize:>65535;
    threshold: type both, track by_src, count 3, seconds 60;
    classtype:policy-violation;
    sid:9004002; rev:1;
)

# Requête DNS vers domaine suspect (longueur anormale)
alert dns $HOME_NET any -> any 53 (
    msg:"LAB-EXFIL Abnormally Long DNS Query Possible Tunneling";
    dns.query;
    pcre:"/^.{50,}\./";
    classtype:policy-violation;
    sid:9004003; rev:1;
)

# -----------------------------------------------------------------------------
# CATÉGORIE : DÉTECTION D'OUTILS OFFENSIFS
# -----------------------------------------------------------------------------

# Détection Metasploit (User-Agent par défaut)
alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"LAB-EXPLOIT Metasploit HTTP User-Agent";
    content:"Metasploit";
    http_user_agent;
    classtype:attempted-user;
    sid:9005001; rev:1;
)

# Détection SQLmap
alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"LAB-EXPLOIT SQLmap Scan Detected";
    content:"sqlmap";
    http_user_agent;
    nocase;
    classtype:web-application-attack;
    sid:9005002; rev:1;
)

# Détection d'un reverse shell Netcat
alert tcp $HOME_NET any -> $EXTERNAL_NET any (
    msg:"LAB-EXPLOIT Possible Netcat Reverse Shell";
    flow:to_server,established;
    content:"/bin/sh";
    classtype:shellcode-detect;
    sid:9005003; rev:1;
)
